# Required
CORE_DATABASE=coins.db

# Server
HOST=0.0.0.0
PORT=3000
# TLS_CERT_PATH=/path/to/cert.pem
# TLS_KEY_PATH=/path/to/key.pem

# Observability
# OTLP_ENDPOINT=http://localhost:4318

# Solana
# SOLANA_RPC_URL=https://api.mainnet-beta.solana.com
# SOLANA_KEYPAIR_PATH=/path/to/id.json

# DexScreener
# DEXSCREENER_TOKEN_PROFILES_URL=https://api.dexscreener.com/token-profiles/latest/v1
# DEXSCREENER_SEARCH_URL=https://api.dexscreener.com/latest/dex/search

# Scanner (token discovery)
# SCANNER_POLL_INTERVAL_SECS=300
# SPIKE_THRESHOLD=2.0
# BASELINE_WINDOWS=6
# NEW_NARRATIVE_MIN_COUNT=3

# CEX listing monitor
# CEX_POLL_INTERVAL_SECS=300
# CEX_BINANCE_TICKERS_URL=https://api.coingecko.com/api/v3/exchanges/binance/tickers
# CEX_COINBASE_ASSETS_URL=https://www.coinbase.com/api/v2/assets/info

# Telegram signal ingestion
TELEGRAM_BOT_TOKEN=
# TELEGRAM_POLL_INTERVAL_SECS=60

# Distiller (token enrichment & scoring)
# DISTILLER_POLL_INTERVAL_SECS=300

# Portfolio monitor (price tracking, auto-sell conditions)
# PORTFOLIO_POLL_INTERVAL_SECS=60
